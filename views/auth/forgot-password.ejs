<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — StackifyX</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="auth-page">
    <div class="auth-card">

      <!-- Back link -->
      <a href="/auth/login"
         style="display:inline-flex; align-items:center; gap:6px; font-size:0.85rem;
                color:var(--text-muted); margin-bottom:28px; transition:var(--transition);"
         onmouseover="this.style.color='var(--accent-blue)'"
         onmouseout="this.style.color='var(--text-muted)'">
        ← Back to Login
      </a>

      <div class="auth-logo">
        <div class="logo-mark" style="background: linear-gradient(135deg,#f87171,#fbbf24);">🔐</div>
        <h1>Forgot Password?</h1>
        <p>Enter your email and we'll send you a reset link</p>
      </div>

      <!-- Success state -->
      <% if (success) { %>
        <div style="text-align:center; padding:32px 24px; background:rgba(52,211,153,0.06);
                    border:1px solid rgba(52,211,153,0.2); border-radius:var(--radius-lg);">
          <div style="font-size:3rem; margin-bottom:16px;">📬</div>
          <h3 style="color:var(--accent-green); margin-bottom:10px; font-size:1.1rem;">Check your inbox!</h3>
          <p style="font-size:0.88rem; color:var(--text-muted); line-height:1.7;"><%= success %></p>
          <div style="margin-top:24px; padding:14px 16px; background:var(--bg-elevated);
                      border-radius:var(--radius-sm); border:1px solid var(--border);">
            <p style="font-size:0.78rem; color:var(--text-muted);">
              ⚠️ Didn't get it? Check your <strong style="color:var(--text-secondary)">spam/junk folder</strong>.
              The link expires in <strong style="color:var(--text-secondary)">30 minutes</strong>.
            </p>
          </div>
          <a href="/auth/login" class="btn btn-secondary" style="margin-top:20px; display:inline-block;">← Back to Login</a>
        </div>

      <!-- Form state -->
      <% } else { %>
        <% if (error) { %>
          <div class="alert alert-error" style="margin-bottom:20px;">
            <span class="alert-icon">!</span>
            <span><%= error %></span>
          </div>
        <% } %>

        <form action="/auth/forgot-password" method="POST" novalidate>
          <div class="form-group">
            <label for="email">Registered Email Address</label>
            <input type="email" id="email" name="email"
              placeholder="you@example.com"
              required autocomplete="email" autofocus>
            <div style="font-size:0.78rem; color:var(--text-muted); margin-top:6px;">
              Enter the email address linked to your account. We'll send a secure reset link valid for 30 minutes.
            </div>
          </div>

          <button type="submit" class="btn btn-primary btn-block btn-lg">
            Send Reset Link →
          </button>
        </form>

        <div style="text-align:center; margin-top:24px; font-size:0.88rem; color:var(--text-muted);">
          Remembered your password?
          <a href="/auth/login" style="color:var(--accent-blue); font-weight:600;">Sign in</a>
        </div>
      <% } %>

    </div>
  </div>
</body>
</html>
