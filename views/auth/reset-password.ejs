<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — DevCraft Studio</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="auth-page">
    <div class="auth-card">

      <% if (!token) { %>
        <!-- Invalid / expired token -->
        <div style="text-align:center; padding:32px 16px;">
          <div style="font-size:3.5rem; margin-bottom:16px;">⏰</div>
          <h2 style="margin-bottom:12px; color:var(--accent-red);">Link Expired</h2>
          <p style="font-size:0.9rem; color:var(--text-muted); margin-bottom:28px; line-height:1.7;">
            <%= error %>
          </p>
          <a href="/auth/forgot-password" class="btn btn-primary">Request New Link →</a>
        </div>

      <% } else { %>
        <div class="auth-logo">
          <div class="logo-mark" style="background:linear-gradient(135deg,#34d399,#63b3ed);">🔑</div>
          <h1>Set New Password</h1>
          <p>Choose a strong password for your account</p>
        </div>

        <% if (error) { %>
          <div class="alert alert-error" style="margin-bottom:20px;">
            <span class="alert-icon">!</span>
            <span><%= error %></span>
          </div>
        <% } %>

        <form action="/auth/reset-password/<%= token %>" method="POST" novalidate id="resetForm">
          <div class="form-group">
            <label for="password">New Password</label>
            <div style="position:relative;">
              <input type="password" id="password" name="password"
                placeholder="Minimum 6 characters"
                required minlength="6" autocomplete="new-password"
                style="padding-right:48px;">
              <button type="button" onclick="togglePwd('password','eyeIcon1')"
                style="position:absolute;right:12px;top:50%;transform:translateY(-50%);
                       background:none;border:none;cursor:pointer;font-size:1.1rem;line-height:1;"
                id="eyeIcon1">👁</button>
            </div>
            <!-- Strength meter -->
            <div style="margin-top:8px;">
              <div style="height:4px; background:var(--bg-elevated); border-radius:2px; overflow:hidden;">
                <div id="strengthBar" style="height:100%; width:0; border-radius:2px; transition:all 0.3s;"></div>
              </div>
              <div id="strengthText" style="font-size:0.72rem; color:var(--text-muted); margin-top:4px;"></div>
            </div>
          </div>

          <div class="form-group">
            <label for="confirmPassword">Confirm New Password</label>
            <div style="position:relative;">
              <input type="password" id="confirmPassword" name="confirmPassword"
                placeholder="Repeat your password"
                required autocomplete="new-password"
                style="padding-right:48px;">
              <button type="button" onclick="togglePwd('confirmPassword','eyeIcon2')"
                style="position:absolute;right:12px;top:50%;transform:translateY(-50%);
                       background:none;border:none;cursor:pointer;font-size:1.1rem;line-height:1;"
                id="eyeIcon2">👁</button>
            </div>
            <div id="matchText" style="font-size:0.72rem; margin-top:4px;"></div>
          </div>

          <!-- Requirements checklist -->
          <div style="padding:14px 16px; background:var(--bg-elevated); border-radius:var(--radius-sm);
                      border:1px solid var(--border); margin-bottom:20px;">
            <div style="font-size:0.72rem; font-weight:700; text-transform:uppercase;
                        letter-spacing:0.05em; color:var(--text-muted); margin-bottom:8px;">
              Password Requirements
            </div>
            <div id="req-len"  class="req-item">○ At least 6 characters</div>
            <div id="req-num"  class="req-item">○ Contains a number</div>
            <div id="req-spec" class="req-item">○ Contains a special character</div>
          </div>

          <button type="submit" class="btn btn-primary btn-block btn-lg" id="submitBtn" disabled>
            Reset Password →
          </button>
        </form>
      <% } %>

    </div>
  </div>

  <style>
    .req-item { font-size: 0.78rem; color: var(--text-muted); padding: 2px 0; transition: color 0.2s; }
    .req-item.pass { color: var(--accent-green); }
    .req-item.pass::first-letter { /* dot */ }
  </style>

  <script>
    const pwdInput     = document.getElementById('password');
    const confirmInput = document.getElementById('confirmPassword');
    const strengthBar  = document.getElementById('strengthBar');
    const strengthText = document.getElementById('strengthText');
    const matchText    = document.getElementById('matchText');
    const submitBtn    = document.getElementById('submitBtn');
    const reqLen       = document.getElementById('req-len');
    const reqNum       = document.getElementById('req-num');
    const reqSpec      = document.getElementById('req-spec');

    function togglePwd(inputId, btnId) {
      const inp = document.getElementById(inputId);
      inp.type = inp.type === 'password' ? 'text' : 'password';
    }

    function checkStrength(pwd) {
      let score = 0;
      const hasLen  = pwd.length >= 6;
      const hasNum  = /\d/.test(pwd);
      const hasSpec = /[!@#$%^&*(),.?":{}|<>_\-]/.test(pwd);
      const hasUpper = /[A-Z]/.test(pwd);

      if (hasLen)  score++;
      if (hasNum)  score++;
      if (hasSpec) score++;
      if (hasUpper) score++;
      if (pwd.length >= 10) score++;

      // Update checklist
      reqLen.className  = 'req-item' + (hasLen  ? ' pass' : '');
      reqLen.textContent  = (hasLen  ? '✓' : '○') + ' At least 6 characters';
      reqNum.className  = 'req-item' + (hasNum  ? ' pass' : '');
      reqNum.textContent  = (hasNum  ? '✓' : '○') + ' Contains a number';
      reqSpec.className = 'req-item' + (hasSpec ? ' pass' : '');
      reqSpec.textContent = (hasSpec ? '✓' : '○') + ' Contains a special character';

      // Strength bar
      const colors  = ['#f87171','#fbbf24','#fbbf24','#34d399','#10b981'];
      const labels  = ['Too weak','Weak','Fair','Strong','Very strong'];
      const widths  = ['20%','40%','60%','80%','100%'];
      const idx     = Math.min(score - 1, 4);
      if (score > 0) {
        strengthBar.style.width      = widths[idx];
        strengthBar.style.background = colors[idx];
        strengthText.textContent     = labels[idx];
        strengthText.style.color     = colors[idx];
      } else {
        strengthBar.style.width = '0';
        strengthText.textContent = '';
      }

      return hasLen;
    }

    function validate() {
      const pwd = pwdInput.value;
      const cpw = confirmInput.value;
      const lenOk   = checkStrength(pwd);
      const matchOk = cpw.length === 0 || pwd === cpw;

      if (cpw.length > 0) {
        matchText.textContent = pwd === cpw ? '✓ Passwords match' : '✗ Passwords do not match';
        matchText.style.color = pwd === cpw ? 'var(--accent-green)' : 'var(--accent-red)';
      } else {
        matchText.textContent = '';
      }

      submitBtn.disabled = !(lenOk && pwd === cpw && cpw.length > 0);
    }

    pwdInput.addEventListener('input', validate);
    confirmInput.addEventListener('input', validate);
  </script>
</body>
</html>
