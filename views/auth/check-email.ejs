<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="icon" type="image/jpeg" href="/stackifyx-logo.jpg">
    <!-- Anti-flash: apply saved theme before first paint -->
    <script>if(localStorage.getItem('devcraft-theme')==='light')document.documentElement.classList.add('light');</script>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> — StackifyX</title>
    <link rel="stylesheet" href="/css/style.css">
  </head>
<body>
  <%- include('../partials/navbar') %>
  <div class="auth-page">
    <div class="auth-card" style="text-align:center;">

      <% if (locals.alreadyVerified) { %>
        <div style="font-size:3rem;margin-bottom:16px;">✅</div>
        <h2 style="margin-bottom:10px;">Already Verified!</h2>
        <p style="margin-bottom:24px;">Your email is already verified. You can sign in now.</p>
        <a href="/auth/login" class="btn btn-primary">Sign In →</a>

      <% } else { %>
        <!-- Animated envelope -->
        <div style="font-size:4rem;margin-bottom:20px;animation:bounce 1.5s infinite alternate;">📬</div>

        <h1 style="font-size:1.6rem;margin-bottom:10px;">Check Your Inbox!</h1>
        <p style="color:var(--text-muted);margin-bottom:6px;font-size:0.95rem;">
          We sent a verification link to:
        </p>
        <div style="display:inline-block;padding:10px 20px;background:var(--bg-elevated);
                    border:1px solid var(--border-accent);border-radius:var(--radius-sm);
                    font-family:var(--font-mono);color:var(--accent-blue);font-size:0.95rem;
                    margin-bottom:24px;">
          <%= email %>
        </div>

        <p style="font-size:0.88rem;color:var(--text-muted);margin-bottom:28px;line-height:1.7;max-width:360px;margin-left:auto;margin-right:auto;">
          Click the link in the email to activate your account.
          The link expires in <strong style="color:var(--text-secondary)">24 hours</strong>.
        </p>

        <!-- Steps -->
        <div style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-md);
                    padding:20px;text-align:left;margin-bottom:28px;">
          <div style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;
                      color:var(--text-muted);margin-bottom:14px;">What to do next</div>
          <% [
            ['📧','Open your email inbox'],
            ['🔍','Look for an email from StackifyX'],
            ['🗑️','Check spam/junk folder if not found'],
            ['🔗','Click "Verify My Email" button in the email'],
          ].forEach(([icon, text]) => { %>
            <div style="display:flex;gap:10px;align-items:center;padding:7px 0;border-bottom:1px solid var(--border);">
              <span style="font-size:1.1rem;flex-shrink:0;"><%= icon %></span>
              <span style="font-size:0.88rem;color:var(--text-secondary);"><%= text %></span>
            </div>
          <% }) %>
        </div>

        <!-- Resend -->
        <p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:12px;">Didn't receive it?</p>
        <a href="/auth/resend-verification?email=<%= encodeURIComponent(email) %>"
           class="btn btn-secondary" style="margin-bottom:16px;">
          🔄 Resend Verification Email
        </a>

        <div style="margin-top:16px;">
          <a href="/auth/login" style="font-size:0.85rem;color:var(--text-muted);">← Back to Login</a>
        </div>
      <% } %>

    </div>
  </div>

  <style>
    @keyframes bounce {
      from { transform: translateY(0); }
      to   { transform: translateY(-12px); }
    }
  </style>
</body>
</html>
