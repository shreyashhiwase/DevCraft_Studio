<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= project.title %> — DevCraft Studio</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  <div class="page-wrapper">
    <div class="container" style="padding-top:48px; padding-bottom:64px;">

      <div style="margin-bottom:28px;">
        <a href="/dashboard" style="font-size:0.85rem; color:var(--text-muted);">← Dashboard</a>
      </div>

      <%- include('../partials/flash') %>

      <div class="detail-grid">
        <!-- LEFT COLUMN -->
        <div>
          <!-- Project Header -->
          <div class="card" style="margin-bottom:24px;">
            <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:16px; flex-wrap:wrap;">
              <div>
                <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:8px;">
                  <span class="badge" style="background:var(--bg-elevated); color:var(--text-muted); text-transform:capitalize;"><%= project.category %></span>
                  <span class="badge badge-<%= project.status.replace(' ','-') %>"><%= project.status %></span>
                </div>
                <h1 style="font-size:1.6rem; margin-bottom:8px;"><%= project.title %></h1>
                <p style="font-size:0.9rem; line-height:1.7;"><%= project.description %></p>
              </div>
            </div>

            <!-- Progress -->
            <div style="margin-top:24px; padding-top:20px; border-top:1px solid var(--border);">
              <div style="display:flex; justify-content:space-between; margin-bottom:10px; font-size:0.85rem;">
                <span style="color:var(--text-muted); font-weight:600;">Project Progress</span>
                <span style="color:var(--accent-blue); font-family:var(--font-mono); font-weight:700;"><%= project.progress %>%</span>
              </div>
              <div class="progress-bar" style="height:12px;">
                <div class="progress-fill" style="width:<%= project.progress %>%"></div>
              </div>
            </div>

            <!-- Meta -->
            <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:16px; margin-top:24px; padding-top:20px; border-top:1px solid var(--border);">
              <div>
                <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-muted); font-weight:700; margin-bottom:4px;">Price</div>
                <div style="font-family:var(--font-mono); font-size:1.1rem; font-weight:700; color:var(--accent-blue);">₹<%= project.price.toLocaleString('en-IN') %></div>
              </div>
              <div>
                <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-muted); font-weight:700; margin-bottom:4px;">Deadline</div>
                <div style="font-size:0.95rem; color:var(--text-primary); font-weight:600;">
                  <%= project.deadline ? new Date(project.deadline).toLocaleDateString('en-IN', { dateStyle: 'medium' }) : 'TBD' %>
                </div>
              </div>
              <div>
                <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-muted); font-weight:700; margin-bottom:4px;">Payment</div>
                <span class="badge badge-<%= project.paymentStatus === 'paid' ? 'completed' : project.paymentStatus === 'partial' ? 'in-progress' : 'pending' %>"><%= project.paymentStatus %></span>
              </div>
              <% if (project.startedAt) { %>
              <div>
                <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-muted); font-weight:700; margin-bottom:4px;">Started</div>
                <div style="font-size:0.95rem; color:var(--text-primary);">
                  <%= new Date(project.startedAt).toLocaleDateString('en-IN', { dateStyle: 'medium' }) %>
                </div>
              </div>
              <% } %>
            </div>

            <!-- Links -->
            <% if (project.githubLink || project.liveLink) { %>
              <div style="display:flex; gap:12px; margin-top:20px; flex-wrap:wrap;">
                <% if (project.githubLink) { %>
                  <a href="<%= project.githubLink %>" target="_blank" class="btn btn-secondary btn-sm">🔗 GitHub</a>
                <% } %>
                <% if (project.liveLink) { %>
                  <a href="<%= project.liveLink %>" target="_blank" class="btn btn-success btn-sm">🚀 Live Demo</a>
                <% } %>
              </div>
            <% } %>

            <!-- Tech Stack -->
            <% if (project.techStack && project.techStack.length > 0) { %>
              <div style="margin-top:16px; display:flex; gap:6px; flex-wrap:wrap;">
                <% project.techStack.forEach(t => { %>
                  <span style="padding:4px 12px; background:var(--bg-elevated); border:1px solid var(--border); border-radius:100px; font-size:0.78rem; color:var(--text-muted); font-family:var(--font-mono);"><%= t %></span>
                <% }) %>
              </div>
            <% } %>

            <div style="margin-top:20px;">
              <a href="/chat/<%= project._id %>" class="btn btn-primary">💬 Open Project Chat →</a>
            </div>
          </div>

          <!-- Milestones -->
          <% if (project.milestones && project.milestones.length > 0) { %>
            <div class="card" style="margin-bottom:24px;">
              <div class="card-header">
                <span class="card-title">📌 Milestones</span>
                <span style="font-size:0.8rem; color:var(--text-muted);"><%= project.milestones.filter(m=>m.completed).length %>/<%= project.milestones.length %> done</span>
              </div>
              <% project.milestones.forEach(m => { %>
                <div class="milestone-item <%= m.completed ? 'done' : '' %>">
                  <div class="milestone-check"><%= m.completed ? '✓' : '' %></div>
                  <div class="milestone-info">
                    <div class="milestone-title"><%= m.title %></div>
                    <% if (m.description) { %><div class="milestone-desc"><%= m.description %></div><% } %>
                    <% if (m.dueDate) { %><div class="milestone-desc">Due: <%= new Date(m.dueDate).toLocaleDateString('en-IN', {dateStyle:'medium'}) %></div><% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>

          <!-- Deliverable Files -->
          <% if (project.files && project.files.length > 0) { %>
            <div class="card" style="margin-bottom:24px;">
              <div class="card-header"><span class="card-title">📦 Deliverable Files</span></div>
              <% project.files.forEach(file => { %>
                <div class="file-item">
                  <span class="file-icon">📄</span>
                  <div class="file-info">
                    <div class="file-name"><%= file.originalName %></div>
                    <div class="file-size"><%= (file.size / 1024).toFixed(1) %> KB</div>
                  </div>
                  <a href="<%= file.path %>" download="<%= file.originalName %>" class="btn btn-secondary btn-sm">⬇ Download</a>
                </div>
              <% }) %>
            </div>
          <% } %>

          <!-- Review -->
          <% if (project.status === 'completed') { %>
            <div class="card">
              <div class="card-header"><span class="card-title">⭐ Rate & Review</span></div>
              <% if (review) { %>
                <div style="display:flex; gap:4px; margin-bottom:12px;">
                  <% for(let i=1;i<=5;i++) { %>
                    <span class="star <%= i <= review.rating ? 'filled' : '' %>">★</span>
                  <% } %>
                  <span style="font-size:0.85rem; color:var(--text-muted); margin-left:8px;"><%= review.rating %>/5</span>
                </div>
                <% if (review.title) { %><h4 style="margin-bottom:6px;"><%= review.title %></h4><% } %>
                <p style="font-size:0.9rem;"><%= review.feedback %></p>
                <p style="font-size:0.78rem; color:var(--text-muted); margin-top:8px;">Reviewed on <%= new Date(review.createdAt).toLocaleDateString('en-IN') %></p>
              <% } else { %>
                <p style="margin-bottom:20px; font-size:0.9rem;">How was your experience? Your feedback helps us improve.</p>
                <form action="/reviews/<%= project._id %>" method="POST">
                  <div class="form-group">
                    <label>Overall Rating *</label>
                    <div style="display:flex; gap:8px;" id="starRating">
                      <% for(let i=1;i<=5;i++) { %>
                        <label style="cursor:pointer; text-transform:none; font-size:1.6rem; letter-spacing:0;">
                          <input type="radio" name="rating" value="<%= i %>" required style="display:none;">
                          <span class="rating-star" data-val="<%= i %>" style="transition:var(--transition);">☆</span>
                        </label>
                      <% } %>
                    </div>
                  </div>
                  <div class="form-row">
                    <div class="form-group">
                      <label>Communication</label>
                      <select name="communication">
                        <option value="">-</option>
                        <% for(let i=1;i<=5;i++) { %><option value="<%= i %>"><%= i %> ★</option><% } %>
                      </select>
                    </div>
                    <div class="form-group">
                      <label>Quality</label>
                      <select name="quality">
                        <option value="">-</option>
                        <% for(let i=1;i<=5;i++) { %><option value="<%= i %>"><%= i %> ★</option><% } %>
                      </select>
                    </div>
                    <div class="form-group">
                      <label>Timeliness</label>
                      <select name="timeliness">
                        <option value="">-</option>
                        <% for(let i=1;i<=5;i++) { %><option value="<%= i %>"><%= i %> ★</option><% } %>
                      </select>
                    </div>
                    <div class="form-group">
                      <label>Value for Money</label>
                      <select name="value">
                        <option value="">-</option>
                        <% for(let i=1;i<=5;i++) { %><option value="<%= i %>"><%= i %> ★</option><% } %>
                      </select>
                    </div>
                  </div>
                  <div class="form-group">
                    <label>Review Title</label>
                    <input type="text" name="title" placeholder="Summarize your experience" maxlength="100">
                  </div>
                  <div class="form-group">
                    <label>Your Feedback *</label>
                    <textarea name="feedback" rows="4" placeholder="Tell us about your project experience..." required maxlength="1000"></textarea>
                  </div>
                  <button type="submit" class="btn btn-primary">Submit Review →</button>
                </form>
              <% } %>
            </div>
          <% } %>
        </div>

        <!-- RIGHT SIDEBAR -->
        <div>
          <!-- Payment Card -->
          <div class="card" style="margin-bottom:24px;">
            <div class="card-header"><span class="card-title">💳 Payment</span></div>
            <div style="margin-bottom:16px;">
              <div style="display:flex; justify-content:space-between; margin-bottom:8px; font-size:0.85rem;">
                <span style="color:var(--text-muted);">Project Price</span>
                <span style="color:var(--text-primary); font-family:var(--font-mono); font-weight:600;">₹<%= project.price.toLocaleString('en-IN') %></span>
              </div>
              <div style="display:flex; justify-content:space-between; margin-bottom:8px; font-size:0.85rem;">
                <span style="color:var(--text-muted);">Amount Paid</span>
                <span style="color:var(--accent-green); font-family:var(--font-mono); font-weight:600;">₹<%= (project.amountPaid || 0).toLocaleString('en-IN') %></span>
              </div>
              <div style="height:1px; background:var(--border); margin:12px 0;"></div>
              <div style="display:flex; justify-content:space-between; font-size:0.95rem; font-weight:700;">
                <span style="color:var(--text-primary);">Balance Due</span>
                <span style="color:var(--accent-orange); font-family:var(--font-mono);">₹<%= Math.max(0, project.price - (project.amountPaid||0)).toLocaleString('en-IN') %></span>
              </div>
            </div>

            <% const balanceDue = Math.max(0, project.price - (project.amountPaid||0)); %>
            <% if (balanceDue > 0 && project.status !== 'cancelled') { %>
              <div style="margin-bottom:12px;">
                <label style="font-size:0.82rem;">Pay Amount (₹)</label>
                <input type="number" id="payAmount" min="1" max="<%= balanceDue %>" value="<%= balanceDue %>"
                  placeholder="Enter amount" style="margin-top:6px;">
              </div>
              <button class="btn btn-primary btn-block" id="payBtn" onclick="initiatePayment()">
                💳 Pay Now
              </button>
            <% } else if (project.paymentStatus === 'paid') { %>
              <div style="text-align:center; padding:16px; background:rgba(52,211,153,0.08); border-radius:var(--radius-sm); border:1px solid rgba(52,211,153,0.2);">
                <div style="font-size:1.5rem; margin-bottom:6px;">✅</div>
                <div style="color:var(--accent-green); font-weight:600; font-size:0.9rem;">Payment Complete</div>
              </div>
            <% } %>

            <!-- Payment History -->
            <% if (payments && payments.length > 0) { %>
              <div style="margin-top:20px; padding-top:16px; border-top:1px solid var(--border);">
                <div style="font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-muted); margin-bottom:12px;">Payment History</div>
                <% payments.filter(p=>p.status==='captured').forEach(p => { %>
                  <div style="display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid var(--border);">
                    <div>
                      <div style="font-size:0.82rem; color:var(--text-primary); font-weight:500;">₹<%= (p.amount/100).toLocaleString('en-IN') %></div>
                      <div style="font-size:0.72rem; color:var(--text-muted);"><%= new Date(p.createdAt).toLocaleDateString('en-IN') %></div>
                    </div>
                    <span class="badge badge-completed" style="font-size:0.7rem;">Paid</span>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>

          <!-- Admin Notes -->
          <% if (project.adminNotes) { %>
            <div class="card">
              <div class="card-header"><span class="card-title">📝 Notes from Admin</span></div>
              <p style="font-size:0.9rem; line-height:1.7;"><%= project.adminNotes %></p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Razorpay Integration -->
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script>
    const PROJECT_ID = '<%= project._id %>';
    const RAZORPAY_KEY = '<%= razorpayKey || "" %>';

    async function initiatePayment() {
      const amount = parseFloat(document.getElementById('payAmount').value);
      if (!amount || amount <= 0) { alert('Please enter a valid amount.'); return; }

      if (!RAZORPAY_KEY) {
        alert('Payment gateway not configured. Please contact admin.');
        return;
      }

      const btn = document.getElementById('payBtn');
      btn.textContent = 'Creating order...'; btn.disabled = true;

      try {
        const res = await fetch('/payments/create-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ projectId: PROJECT_ID, amount })
        });
        const data = await res.json();
        if (!data.success) throw new Error(data.message);

        const options = {
          key: RAZORPAY_KEY,
          amount: data.amount,
          currency: data.currency,
          name: 'DevCraft Studio',
          description: data.projectTitle,
          order_id: data.orderId,
          handler: async function(response) {
            const verifyRes = await fetch('/payments/verify', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ ...response, projectId: PROJECT_ID })
            });
            const verifyData = await verifyRes.json();
            if (verifyData.success) { alert('✅ Payment successful!'); location.reload(); }
            else { alert('Payment verification failed. Contact support.'); }
          },
          prefill: { name: '<%= currentUser.name %>', email: '<%= currentUser.email %>' },
          theme: { color: '#63b3ed' }
        };

        const rzp = new Razorpay(options);
        rzp.open();
      } catch (err) {
        alert('Payment failed: ' + err.message);
      } finally {
        btn.textContent = '💳 Pay Now'; btn.disabled = false;
      }
    }

    // Star rating UI
    const stars = document.querySelectorAll('.rating-star');
    stars.forEach(star => {
      star.parentElement.querySelector('input').addEventListener('change', function() {
        const val = parseInt(this.value);
        stars.forEach((s, i) => {
          s.textContent = i < val ? '★' : '☆';
          s.style.color = i < val ? 'var(--accent-orange)' : 'var(--text-muted)';
        });
      });
      star.addEventListener('mouseover', function() {
        const val = parseInt(this.dataset.val);
        stars.forEach((s, i) => {
          s.style.color = i < val ? 'var(--accent-orange)' : 'var(--text-muted)';
        });
      });
    });
  </script>
</body>
</html>
