<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="icon" type="image/jpeg" href="/stackifyx-logo.jpg">
    <!-- Anti-flash: apply saved theme before first paint -->
    <script>if(localStorage.getItem('devcraft-theme')==='light')document.documentElement.classList.add('light');</script>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> — StackifyX</title>
    <link rel="stylesheet" href="/css/style.css">
  </head>
<body style="overflow:hidden;">
  <%- include('../partials/navbar') %>

  <div class="chat-page">
    <div class="chat-container" style="border-left:1px solid var(--border); border-right:1px solid var(--border);">

      <!-- Chat Header -->
      <div class="chat-header">
        <a href="<%= userRole === 'admin' ? '/admin/projects/'+project._id : '/projects/'+project._id %>"
           style="color:var(--text-muted); font-size:1.2rem; line-height:1; text-decoration:none; flex-shrink:0;">←</a>
        <div style="width:40px; height:40px; background:var(--gradient-primary); border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1.1rem; flex-shrink:0;">
          <%= project.category === 'web' ? '🌐' : project.category === 'mobile' ? '📱' : '💻' %>
        </div>
        <div style="flex:1; min-width:0;">
          <div style="font-family:var(--font-display); font-weight:700; color:var(--text-primary); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
            <%= project.title %>
          </div>
          <div style="font-size:0.75rem; color:var(--text-muted); margin-top:2px;">
            <% if (userRole === 'admin') { %>
              Client: <%= project.user ? project.user.name : 'N/A' %>
            <% } else { %>
              Chat with StackifyX team
            <% } %>
          </div>
        </div>
        <span class="badge badge-<%= project.status.replace(' ','-') %>" style="flex-shrink:0;"><%= project.status %></span>
      </div>

      <!-- Messages Area -->
      <div class="chat-messages" id="messagesContainer">
        <% if (messages && messages.length > 0) { %>
          <% messages.forEach(msg => { %>
            <% const isOwn = msg.sender && msg.sender._id && msg.sender._id.toString() === currentUserId.toString(); %>
            <div class="message <%= isOwn ? 'own' : '' %>">
              <div class="message-avatar">
                <%= msg.sender ? msg.sender.name.charAt(0).toUpperCase() : '?' %>
              </div>
              <div class="message-body">
                <div class="message-name">
                  <%= isOwn ? 'You' : (msg.senderRole === 'admin' ? '⚡ Admin' : msg.sender.name) %>
                </div>
                <div class="message-bubble"><%= msg.content %></div>
                <div class="message-time">
                  <%= new Date(msg.createdAt).toLocaleTimeString('en-IN', {hour:'2-digit', minute:'2-digit'}) %>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div style="text-align:center; padding:48px 24px; color:var(--text-muted);">
            <div style="font-size:3rem; margin-bottom:12px; opacity:0.5;">💬</div>
            <div style="font-weight:600; color:var(--text-secondary); margin-bottom:6px;">No messages yet</div>
            <div style="font-size:0.85rem;">Start the conversation below</div>
          </div>
        <% } %>
      </div>

      <!-- Typing Indicator -->
      <div class="typing-indicator" id="typingIndicator">
        <span id="typingText">Someone is typing...</span>
      </div>

      <!-- Input Area -->
      <div class="chat-input-area">
        <div style="width:36px; height:36px; background:var(--gradient-primary); border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; color:#fff; font-family:var(--font-display); flex-shrink:0;">
          <%= currentUser.name.charAt(0).toUpperCase() %>
        </div>
        <input
          type="text" id="chatInput" class="chat-input"
          placeholder="Type your message..."
          maxlength="2000"
          autocomplete="off"
        >
        <button class="btn btn-primary btn-sm" id="sendBtn" onclick="sendMessage()">Send →</button>
      </div>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const PROJECT_ID = '<%= projectId %>';
    const CURRENT_USER_ID = '<%= currentUserId %>';
    const USER_ROLE = '<%= userRole %>';
    const USER_NAME = '<%= currentUser.name %>';

    const socket = io();
    const container = document.getElementById('messagesContainer');
    const input = document.getElementById('chatInput');
    const typingIndicator = document.getElementById('typingIndicator');
    const typingText = document.getElementById('typingText');

    // Scroll to bottom
    function scrollToBottom() {
      container.scrollTop = container.scrollHeight;
    }
    scrollToBottom();

    // Join room
    socket.emit('join-project', PROJECT_ID);

    // Receive messages
    socket.on('new-message', (msg) => {
      const isOwn = msg.sender && msg.sender._id === CURRENT_USER_ID;
      const time = new Date(msg.createdAt).toLocaleTimeString('en-IN', {hour:'2-digit', minute:'2-digit'});
      const senderName = isOwn ? 'You' : (msg.senderRole === 'admin' ? '⚡ Admin' : msg.sender.name);
      const initial = msg.sender ? msg.sender.name.charAt(0).toUpperCase() : '?';

      const msgEl = document.createElement('div');
      msgEl.className = `message ${isOwn ? 'own' : ''}`;
      msgEl.innerHTML = `
        <div class="message-avatar">${initial}</div>
        <div class="message-body">
          <div class="message-name">${senderName}</div>
          <div class="message-bubble">${escapeHtml(msg.content)}</div>
          <div class="message-time">${time}</div>
        </div>
      `;

      // Remove empty state
      const emptyState = container.querySelector('[style*="padding:48px"]');
      if (emptyState) emptyState.remove();

      container.appendChild(msgEl);
      scrollToBottom();
    });

    // Typing indicators
    let typingTimer;
    socket.on('user-typing', (data) => {
      if (data.userId !== CURRENT_USER_ID) {
        typingText.textContent = data.role === 'admin' ? 'Admin is typing...' : 'Client is typing...';
        typingIndicator.classList.add('show');
      }
    });
    socket.on('user-stop-typing', () => typingIndicator.classList.remove('show'));

    function sendMessage() {
      const content = input.value.trim();
      if (!content) return;
      socket.emit('send-message', { projectId: PROJECT_ID, content });
      input.value = '';
      socket.emit('stop-typing', { projectId: PROJECT_ID });
    }

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
    });

    input.addEventListener('input', () => {
      socket.emit('typing', { projectId: PROJECT_ID });
      clearTimeout(typingTimer);
      typingTimer = setTimeout(() => socket.emit('stop-typing', { projectId: PROJECT_ID }), 2000);
    });

    function escapeHtml(str) {
      return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;');
    }

    socket.on('error', (data) => console.error('Socket error:', data));
  </script>
</body>
</html>
